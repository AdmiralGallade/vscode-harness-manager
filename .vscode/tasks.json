{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: esbuild",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "esbuild"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm",
      "args": [
        "test"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "npm: lint",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint"
      ],
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "npm: package",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "vsce:package"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
