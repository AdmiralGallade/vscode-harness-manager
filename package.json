{
  "name": "harness-manager",
  "displayName": "Harness Manager",
  "description": "Install and manage AI agent harnesses for VS Code, Cursor, and Windsurf. Instantly configures Claude Code, GitHub Copilot, Cursor, and Windsurf with the right instructions for your workflow.",
  "version": "0.1.6",
  "publisher": "AdmiralGallade",
  "author": {
    "name": "Harness Team"
  },
  "icon": "media/harness-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdmiralGallade/vscode-harness-manager"
  },
  "bugs": {
    "url": "https://github.com/AdmiralGallade/vscode-harness-manager/issues"
  },
  "homepage": "https://github.com/AdmiralGallade/vscode-harness-manager",
  "keywords": [
    "harness",
    "ai",
    "agent",
    "claude",
    "copilot",
    "cursor",
    "windsurf",
    "prompt",
    "rules",
    "instructions",
    "workflow",
    "template"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCommand:harness-manager.selectHarness",
    "onCommand:harness-manager.refreshList",
    "onCommand:harness-manager.createHarness",
    "onCommand:harness-manager.switchRepo",
    "onCommand:harness-manager.openSettings",
    "onView:harness-manager.harnessExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "harness-manager.selectHarness",
        "title": "Select and Create Harness",
        "category": "Harness Manager"
      },
      {
        "command": "harness-manager.refreshList",
        "title": "Refresh Harness List",
        "category": "Harness Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "harness-manager.createHarness",
        "title": "Create Harness Scaffold",
        "category": "Harness Manager"
      },
      {
        "command": "harness-manager.switchRepo",
        "title": "Switch Harness Repository",
        "category": "Harness Manager"
      },
      {
        "command": "harness-manager.openSettings",
        "title": "Open Harness Manager Settings",
        "category": "Harness Manager",
        "icon": "$(settings-gear)"
      }
    ],
    "views": {
      "harness-manager": [
        {
          "id": "harness-manager.harnessExplorer",
          "name": "Harnesses",
          "type": "webview"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "harness-manager",
          "title": "Harness Manager",
          "icon": "media/harness-icon.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "harness-manager.refreshList",
          "when": "view == harness-manager.harnessExplorer",
          "group": "navigation@1"
        },
        {
          "command": "harness-manager.openSettings",
          "when": "view == harness-manager.harnessExplorer",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Harness Manager",
      "properties": {
        "harnessManager.githubRepo": {
          "type": "string",
          "default": "AdmiralGallade/harness-repository",
          "description": "GitHub repository containing harness definitions (format: owner/repo)"
        },
        "harnessManager.cacheRefreshInterval": {
          "type": "number",
          "default": 86400000,
          "description": "Cache refresh interval in milliseconds (default: 24 hours)"
        },
        "harnessManager.githubBranch": {
          "type": "string",
          "default": "main",
          "description": "GitHub branch to use when fetching harness files"
        },
        "harnessManager.defaultCreateLocation": {
          "type": "string",
          "enum": [
            "workspace-root",
            "prompt"
          ],
          "default": "workspace-root",
          "description": "Where to create harness files by default"
        },
        "harnessManager.activeHarnessId": {
          "type": "string",
          "default": "",
          "description": "ID of the currently active harness (set automatically when a harness is installed)"
        },
        "harnessManager.multiHarnessInstall": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, installing a harness will not remove other installed harnesses. All installed harnesses coexist in agent-harnesses/."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "vsce:package": "vsce package",
    "ovsx:publish": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.2",
    "@vscode/vsce": "^2.20.0",
    "esbuild": "^0.18.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "mocha": "^10.2.0",
    "ovsx": "^1.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "js-yaml": "^4.1.0"
  }
}
